#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Commit insight pipeline — fail-open so commits succeed even without the script
if ! command -v python3 >/dev/null 2>&1; then
  echo "[post-commit] skipped insight pipeline: python3 not found in PATH"
elif [ ! -f "$HOME/.claude/hooks/commit-insight.py" ]; then
  echo "[post-commit] skipped insight pipeline: $HOME/.claude/hooks/commit-insight.py not found"
else
  python3 "$HOME/.claude/hooks/commit-insight.py" || echo "[post-commit] insight pipeline exited with error (ignored)"
fi
